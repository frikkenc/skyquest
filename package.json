  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.102.0",
    "@tanstack/react-query": "^5.100.9",
    "@vitejs/plugin-react": "^6.0.1",
    "firebase": "^12.13.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.0"
  }
}
