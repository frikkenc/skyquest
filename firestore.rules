rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /eventConfig/{docId} {
      allow read, write: if request.auth != null;
    }
    // Frikken Crazy 8s — formation master list + per-year menu/market.
    match /crazy8config/{docId} {
      allow read, write: if request.auth != null;
    }
    // SkyQuest published event results — public read, admin write.
    match /results_2026/{instanceId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
